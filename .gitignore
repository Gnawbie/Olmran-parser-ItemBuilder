__pycache__/
*.pyc

# Build artifacts / release zips - distributed via GitHub Releases instead
*.zip

# PyInstaller build output/spec - the .exe itself is a GitHub Release asset,
# not something tracked in the repo
build/
dist/
*.spec

# Old test/scratch data, not part of the release
prased/

# Local per-user settings (created next to the script when run from source)
.gaming_log_parser_config.json
