__pycache__/
*.pyc

# Build artifacts / release zips - distributed via GitHub Releases instead
*.zip

# PyInstaller build output/spec - the .exe itself is a GitHub Release asset,
# not something tracked in the repo
build/
dist/
*.spec

# Old test/scratch data, not part of the release
prased/
old/

# Local per-user settings (created next to the script when run from source)
.gaming_log_parser_config.json

# Pre-release test build - launches with a hard-cleaned, isolated config
# (see App.__init__'s OLMRAN_TEST_CONFIG handling) so changes can be tried
# from a clean slate before a real version bump/push. Local-only, never
# committed/pushed - the exe is rebuilt fresh from whatever's currently
# staged for release, tested, then a normal version bump follows.
test_launcher.py
OlmranItemBuilder_TEST.exe
.gaming_log_parser_TEST_config.json

# Ad-hoc "build an older tagged version for comparison" test exe(s) - built
# from an extracted old commit's script, never a real release artifact.
OlmranItemBuilder_TEST_OLD*.exe
